# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.buildlog/
.history
.svn/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
/build/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Third-party vendored packages — ignore build cache artifacts
third_party/**/.cxx/
third_party/**/pubspec.lock
third_party/**/example/android/local.properties
third_party/**/example/android/app/src/main/java/
third_party/**/example/ios/Flutter/Generated.xcconfig
third_party/**/example/ios/Flutter/ephemeral/
third_party/**/example/ios/Flutter/flutter_export_environment.sh
third_party/**/example/ios/Runner/GeneratedPluginRegistrant.*
third_party/**/example/linux/flutter/ephemeral/
third_party/**/example/macos/Flutter/ephemeral/
third_party/**/example/macos/Flutter/GeneratedPluginRegistrant.swift
third_party/**/example/windows/flutter/ephemeral/

# Kotlin build cache
android/.kotlin/

# Dev artifacts
pubspec_overrides.yaml
